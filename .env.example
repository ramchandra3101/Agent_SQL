# ============================================================================
#  SQL Agent — environment template
# ----------------------------------------------------------------------------
#  1. Copy this file:    cp .env.example .env
#  2. Fill in the values marked <...>.
#  3. Never commit the real .env — it is in .gitignore.
# ============================================================================

# ---- OpenAI -----------------------------------------------------------------
# Used for:
#   * SQL generation, routing, schema selection, self-correction, NL summary
#   * Embeddings for the Golden SQL few-shot store (pgvector)
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Database (local Postgres 17 + pgvector) --------------------------------
# Driver:  SQLAlchemy + psycopg3
# Database name is quoted everywhere because it contains an underscore is fine
# but the name is case-sensitive — keep it exactly as `SQL_POC`.
DATABASE_URL=postgresql+psycopg://postgres:<YOUR_POSTGRES_PASSWORD>@localhost:5432/SQL_POC

# ---- LangSmith tracing (optional but recommended) ---------------------------
# Leave LANGSMITH_TRACING=false if you don't have a LangSmith account yet.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=<YOUR_LANGSMITH_API_KEY>
LANGSMITH_PROJECT=sql-agent-poc

# ---- Guardrail budgets ------------------------------------------------------
# Per-run caps enforced by the graph (see plan.md §4, §7).
MAX_RETRIES=2                 # self-correction loops after a failing query
MAX_SQL_GENERATIONS=3         # total SQL generations per user question
ROW_SCAN_BUDGET=100000        # planner-estimated rows above which we pause for HITL
QUERY_TIMEOUT_SECONDS=15      # statement_timeout applied to every query
